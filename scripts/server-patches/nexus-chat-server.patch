+              />
+            </div>
+            <button
+              className="splash-start-btn"
+              onClick={handleAdd}
+              disabled={isAdding || !serverName.trim()}
+              style={{ width: '100%', fontSize: 13 }}
+            >
+              <Plus size={14} />
+              {isAdding ? 'Adding…' : 'Add Server'}
+            </button>
+          </div>
+        )}
+      </div>
+    </div>
+  )
+}

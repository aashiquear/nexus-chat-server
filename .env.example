# ============================================================
# Nexus Chat Server - Environment Variables
# ============================================================
# Copy this file to .env and fill in required values.
# ============================================================

# Required on first run — used to bootstrap the admin account
NEXUS_ADMIN_PASSWORD=your-secure-password-here

# Optional but strongly recommended in production
NEXUS_JWT_SECRET=your-random-secret-here

# Ollama server address (from inside Docker, host.docker.internal reaches the host)
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_API_KEY=
